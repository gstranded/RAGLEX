# Copy this file to `.env.local` before local deployment.
# Scripts in `./scripts` will source it automatically.

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=5000
# Relative SQLite paths are resolved from the repository root by ./scripts/*.sh.
DEV_DATABASE_URL=sqlite:///law_backend_flask/data/raglex-dev.sqlite3
MINIO_DISABLED=true

# Frontend
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=13000
VITE_PROXY_TARGET=http://127.0.0.1:5000
# Keep empty for same-origin deployment. Set it when the frontend is hosted elsewhere.
VITE_API_BASE_URL=

# LLM
# Default is local Ollama in OpenAI-compatible mode.
OPENAI_COMPAT_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_COMPAT_API_KEY=ollama
OPENAI_CHAT_MODEL=qwen2.5:7b

# Optional: external OpenAI-compatible endpoints
# OPENAI_COMPAT_BASE_URL=https://your-openai-compatible-endpoint/v1
# OPENAI_COMPAT_API_KEY=your-api-key
# OPENAI_CHAT_MODEL=gpt-4o-mini

# Optional legacy external RAG service
# CHAT_SERVICE_URL=http://127.0.0.1:10086
