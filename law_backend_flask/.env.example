# Flask
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# Database
# Local default: SQLite
DEV_DATABASE_URL=sqlite:///data/raglex-dev.sqlite3

# Optional: MySQL
# DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/raglex_law

# Object storage
# Local default: disable MinIO and use filesystem fallback.
MINIO_DISABLED=true
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=law-documents
MINIO_SECURE=False

# LLM
# Local default: Ollama in OpenAI-compatible mode.
OPENAI_COMPAT_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_COMPAT_API_KEY=ollama
OPENAI_CHAT_MODEL=qwen2.5:7b

# Optional external OpenAI-compatible endpoint
# OPENAI_COMPAT_BASE_URL=https://your-endpoint.example.com/v1
# OPENAI_COMPAT_API_KEY=your-api-key
# OPENAI_CHAT_MODEL=gpt-4o-mini

# Optional external RAG service
# CHAT_SERVICE_URL=http://127.0.0.1:10086
